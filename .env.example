# Evidence Storage Service - Environment Variables

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Application name
APP_NAME=Evidence Storage Service

# Application version  
APP_VERSION=1.0.0

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# API server configuration
API_HOST=0.0.0.0
API_PORT=8080

# ============================================
# AZURE STORAGE / AZURITE CONFIGURATION
# ============================================

# Azurite account name (devstoreaccount for Azurite)
AZURITE_ACCOUNT_NAME=devstoreaccount

# Azurite account key (default Azurite key)
AZURITE_ACCOUNT_KEY=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBekSoGMHgHb==

# Azurite blob endpoint
AZURITE_BLOB_ENDPOINT=http://azurite:10000/devstoreaccount

# Blob container name
AZURITE_CONTAINER_NAME=evidences